# ================================================
# Umay - Environment Configuration Template
# Copy this file to .env and fill in your values
# ================================================

# Application
APP_NAME=Umay
APP_VERSION=1.0.0
APP_SECRET=CHANGE_THIS_TO_A_RANDOM_SECRET_KEY
JWT_SECRET=CHANGE_THIS_TO_A_RANDOM_JWT_SECRET
DEBUG=false

# Database
POSTGRES_USER=umay_user
POSTGRES_PASSWORD=CHANGE_THIS_DB_PASSWORD
POSTGRES_DB=umay_db
DATABASE_URL=postgresql://umay_user:CHANGE_THIS_DB_PASSWORD@postgres:5432/umay_db

# Redis
REDIS_URL=redis://redis:6379/0

# Admin User (created on first startup)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=CHANGE_THIS_ADMIN_PASSWORD

# Default Tenant
DEFAULT_TENANT_NAME=My Organization
DEFAULT_TENANT_SLUG=my-org

# Ports
BACKEND_PORT=1923
FRONTEND_PORT=1881

# Frontend
REACT_APP_API_URL=http://localhost:8000/api/v1

# Email (optional - for notifications)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com
SMTP_ENABLED=false

# License
LICENSE_KEY=
LICENSE_CHECK_INTERVAL=86400

# Storage
STORAGE_PATH=./storage
BACKUP_PATH=./backups

# Contact
SUPPORT_EMAIL=alikoken@outlook.com

# --- Ports ---
FRONTEND_PORT=1881
BACKEND_PORT=1923
