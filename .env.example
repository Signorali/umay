# =============================================================
# UMAY - Environment Configuration
# Copy this file to .env and fill in the values
# =============================================================

# --- Application ---
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=change-this-to-a-random-secret-key-min-32-chars
APP_NAME=Umay
APP_VERSION=0.1.0

# --- Database ---
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=umay
POSTGRES_USER=umay
POSTGRES_PASSWORD=change-this-password
DATABASE_URL=postgresql+asyncpg://umay:change-this-password@db:5432/umay

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://redis:6379/0

# --- JWT ---
JWT_SECRET_KEY=change-this-jwt-secret-key-min-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- CORS ---
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- File Storage ---
STORAGE_PATH=/app/storage
MAX_UPLOAD_SIZE_MB=10

# --- Backup ---
BACKUP_PATH=/app/backups
BACKUP_ENCRYPTION_KEY=change-this-backup-encryption-key

# --- First Admin (used in installation wizard) ---
FIRST_ADMIN_EMAIL=admin@example.com
FIRST_ADMIN_PASSWORD=change-this-admin-password
FIRST_TENANT_NAME=Default

# --- License ---
LICENSE_KEY=
LICENSE_MODE=trial
